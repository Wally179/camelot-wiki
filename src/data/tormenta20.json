  "calculo": {
    "atributoFinal": "base + racial + subtipo + casa + outros",
    "modificador": "Math.floor((valor - 10) / 2)",
    "pvTotal": "classe.pv.nivel1 + (nivel - 1) * classe.pv.porNivel + (mod(CON) * nivel)",
    "pmTotal": "classe.pmPorNivel[nivel - 1]",
    "cdMagia": "10 + nivel + mod(atributoChave)",
    "defesa": "10 + mod(DES) + bonus",
    "pmMaxPorMagia": "nivel"
  },

